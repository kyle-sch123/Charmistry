# ============================================================================
# Charmistry — Environment Variables
# ============================================================================
# Copy this file to `.env.local` and fill in real values.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser bundle.

# ---- Supabase ----
# The same URL + anon key also power Supabase Auth (Google OAuth + email OTP
# for /account) via @supabase/ssr — no extra env vars needed for auth. Google
# OAuth credentials live in the Supabase dashboard, not here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by /api/checkout, /api/subscribe, /api/account/*, and
# the guest-order claim on sign-in. Never expose in client code. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional. Bucket name for storage-listed product images.
# Defaults to "Charmistry Assets" if unset.
S3_BUCKET_NAME=Charmistry Assets

# ---- PayFast (live payment processor) ----
# Get the merchant ID + key from https://www.payfast.co.za/ → Settings →
# Integration. The passphrase is optional but recommended; if your account
# has one set, it MUST be set here too or signatures will mismatch and the
# ITN will fail validation.
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
# Set to "true" to point at PayFast's sandbox (sandbox.payfast.co.za).
# Anything else (or unset) means live (www.payfast.co.za).
PAYFAST_SANDBOX=true

# ---- Resend (newsletter + order confirmation emails) ----
RESEND_API_KEY=re_xxx
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RESEND_FROM_EMAIL=orders@your-domain.com

# Required: inbox that receives new-order notifications for fulfilment.
MERCHANT_NOTIFICATION_EMAIL=orders@your-domain.com

# ---- Klaviyo ----
# Public onsite-tracking company ID, baked into the browser bundle. Not secret
# (visible in the page source). Defaults to "RDuzmB" if unset. Powers the
# client-side funnel: Active on Site, Viewed Product, Added to Cart, and
# Started Checkout (+ identify) via the onsite klaviyo.js queue.
NEXT_PUBLIC_KLAVIYO_COMPANY_ID=RDuzmB
# Server-only private API key. Leave blank to disable the server-side order
# events (Placed Order + Ordered Product) fired from the PayFast ITN handler.
KLAVIYO_API_KEY=

# ---- Google Analytics (optional) ----
# Leave blank to skip GA script injection.
NEXT_PUBLIC_GA_ID=

# ---- Meta (Facebook) Pixel + Conversions API (optional) ----
# Numeric Pixel ID from Meta Events Manager. Baked into the browser bundle at
# build time (like GA). Leave blank to skip pixel injection. Also reused by the
# server-side Conversions API below.
NEXT_PUBLIC_FB_PIXEL_ID=
# Server-only. System-User access token for the Conversions API (Events Manager
# → Settings → Conversions API → "Generate access token"). Enables the
# server-side Purchase event fired from the PayFast ITN handler, deduped against
# the browser pixel by order id. Leave blank to disable server-side reporting.
META_CAPI_ACCESS_TOKEN=
# Optional. Paste the code from Events Manager → Test Events to route CAPI
# events to the Test Events tab for verification. Leave blank in production.
META_CAPI_TEST_EVENT_CODE=

# ---- Admin fulfilment ----
# Server-only shared secret for the /admin/fulfil console and its API
# (/api/admin/fulfil). Generate with `openssl rand -hex 24`. Leave blank to
# disable the endpoint entirely (it fails closed with 401).
ADMIN_FULFILMENT_KEY=

# ---- Site URL ----
# Used to build absolute return/cancel/notify URLs sent to PayFast.
# Must be reachable from the public internet for the ITN to work.
# For local dev: tunnel via ngrok/cloudflared and set the tunnel URL here.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
