# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by /api/checkout and /api/payfast/notify
# Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Resend (newsletter + order confirmation emails) ----
RESEND_API_KEY=re_xxx
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RESEND_FROM_EMAIL=orders@your-domain.com

# ---- PayFast ----
# Sandbox defaults below. Flip PAYFAST_SANDBOX=false and swap IDs/key for live.
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=jt7NOE43FZPn
PAYFAST_SANDBOX=true

# Public site URL — used to build return/cancel/notify URLs sent to PayFast.
# Must be reachable from the public internet for ITN to work.
# For local dev: tunnel via ngrok/cloudflared and set the tunnel URL here.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
